DATABASE_URL=sqlite+aiosqlite:////home/ubuntu/leetcode/data/leetcode.db
REDIS_URL=redis://127.0.0.1:6379/0

JUDGE_EXECUTOR=docker
JUDGE_DOCKER_IMAGE=leetcode-judge:latest
JUDGE_DOCKER_MEMORY=512m
JUDGE_DOCKER_CPUS=1.0
JUDGE_DOCKER_PIDS_LIMIT=128
JUDGE_DOCKER_TMPFS_SIZE=384m
JUDGE_DOCKER_TIMEOUT_SECONDS=45

SESSION_SECRET_KEY=replace-with-a-random-secret
COOKIE_SECURE=false

AUTO_SEED_DEMO_DATA=true
SEED_ADMIN_NAME=Singh
SEED_ADMIN_USERNAME=replace-with-admin-email
SEED_ADMIN_PASSWORD=replace-with-admin-password
